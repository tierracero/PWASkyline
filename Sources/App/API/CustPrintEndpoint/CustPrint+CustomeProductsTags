
import Foundation
import TCFundamentals
import TCFireSignal

extension CustPrintComponents {
    
    static func customePrintEngine(
        storeId: UUID?,
        scriptId: UUID,
        fileName: String,
        payload: [PrintCustomeProductTagPayload],
        callback: @escaping ( (_ resp: APIResponseGeneric<CustomeProductsTagsResponse>?) -> () )
    ) {
        
        sendPost(
            rout,
            version,
            "customePrintEngine",
            CustomeProductsTagsRequest(
                storeId: storeId,
                scriptId: scriptId,
                fileName: fileName,
                payload: payload
            )
        ) { data in
            guard let data else {
                callback(nil)
                return
            }
            do{
                callback(try JSONDecoder().decode(APIResponseGeneric<CustomeProductsTagsResponse>.self, from: data))
            }
            catch{
                print("🔴 DEOCDING \(#function)")
                print(error)
                callback(nil)
            }
        }
    }
}
